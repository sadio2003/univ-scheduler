<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.univ.scheduler.controller.StatistiquesController">

    <top>
        <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 2);" BorderPane.alignment="CENTER">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Label text="Statistiques et rapports" textFill="#2c3e50">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#exporterRapportPDF" style="-fx-background-color: #e74c3c;" text="📥 Export PDF" textFill="WHITE" />
                        <Button mnemonicParsing="false" onAction="#exporterRapportExcel" style="-fx-background-color: #27ae60;" text="📊 Export Excel" textFill="WHITE" />
                        <Button mnemonicParsing="false" onAction="#imprimerRapport" style="-fx-background-color: #3498db;" text="🖨️ Imprimer" textFill="WHITE" />
                        <Button mnemonicParsing="false" onAction="#actualiserDonnees" style="-fx-background-color: #f39c12;" text="🔄 Actualiser" textFill="WHITE" />
                    </children>
                </HBox>
                <Separator prefWidth="200.0" />
                <Label fx:id="periodeLabel" text="Période du 01/03/2024 au 31/03/2024" textFill="#7f8c8d" />
            </children>
        </VBox>
    </top>

    <center>
        <TabPane fx:id="statistiquesTabPane" tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER">
            <tabs>
                <Tab text="Vue d'ensemble">
                    <content>
                        <ScrollPane fitToWidth="true">
                            <content>
                                <VBox spacing="20.0" style="-fx-padding: 20;">
                                    <children>
                                        <!-- Indicateurs clés -->
                                        <HBox spacing="20.0" style="-fx-padding: 15; -fx-background-color: #f8f9fa; -fx-background-radius: 10;">
                                            <children>
                                                <VBox alignment="CENTER" spacing="5.0" HBox.hgrow="ALWAYS">
                                                    <Label text="Salles" textFill="#7f8c8d" />
                                                    <Label fx:id="totalSallesLabel" text="0" textFill="#2c3e50">
                                                        <font>
                                                            <Font name="System Bold" size="24.0" />
                                                        </font>
                                                    </Label>
                                                </VBox>
                                                <VBox alignment="CENTER" spacing="5.0" HBox.hgrow="ALWAYS">
                                                    <Label text="Cours" textFill="#7f8c8d" />
                                                    <Label fx:id="totalCoursLabel" text="0" textFill="#2c3e50">
                                                        <font>
                                                            <Font name="System Bold" size="24.0" />
                                                        </font>
                                                    </Label>
                                                </VBox>
                                                <VBox alignment="CENTER" spacing="5.0" HBox.hgrow="ALWAYS">
                                                    <Label text="Séances" textFill="#7f8c8d" />
                                                    <Label fx:id="totalSeancesLabel" text="0" textFill="#2c3e50">
                                                        <font>
                                                            <Font name="System Bold" size="24.0" />
                                                        </font>
                                                    </Label>
                                                </VBox>
                                                <VBox alignment="CENTER" spacing="5.0" HBox.hgrow="ALWAYS">
                                                    <Label text="Enseignants" textFill="#7f8c8d" />
                                                    <Label fx:id="totalEnseignantsLabel" text="0" textFill="#2c3e50">
                                                        <font>
                                                            <Font name="System Bold" size="24.0" />
                                                        </font>
                                                    </Label>
                                                </VBox>
                                            </children>
                                        </HBox>

                                        <!-- Graphiques -->
                                        <GridPane hgap="20.0" vgap="20.0">
                                            <columnConstraints>
                                                <ColumnConstraints hgrow="SOMETIMES" percentWidth="50.0" />
                                                <ColumnConstraints hgrow="SOMETIMES" percentWidth="50.0" />
                                            </columnConstraints>

                                            <!-- Taux d'occupation -->
                                            <VBox spacing="10.0" style="-fx-padding: 15; -fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                                <children>
                                                    <Label text="Taux d'occupation global" textFill="#2c3e50">
                                                        <font>
                                                            <Font name="System Bold" size="14.0" />
                                                        </font>
                                                    </Label>
                                                    <ProgressBar fx:id="occupationGlobaleBar" prefWidth="200.0" progress="0.65" />
                                                    <Label fx:id="occupationGlobaleLabel" text="65%" textFill="#3498db">
                                                        <font>
                                                            <Font name="System Bold" size="18.0" />
                                                        </font>
                                                    </Label>
                                                </children>
                                            </VBox>

                                            <!-- Utilisation des salles -->
                                            <VBox spacing="10.0" style="-fx-padding: 15; -fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                                <children>
                                                    <Label text="Utilisation des salles" textFill="#2c3e50">
                                                        <font>
                                                            <Font name="System Bold" size="14.0" />
                                                        </font>
                                                    </Label>
                                                    <ProgressBar fx:id="utilisationSallesBar" prefWidth="200.0" progress="0.42" />
                                                    <Label fx:id="utilisationSallesLabel" text="42%" textFill="#3498db">
                                                        <font>
                                                            <Font name="System Bold" size="18.0" />
                                                        </font>
                                                    </Label>
                                                </children>
                                            </VBox>

                                            <!-- Graphique en barres -->
                                            <VBox spacing="10.0" style="-fx-padding: 15; -fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="1">
                                                <children>
                                                    <Label text="Occupation par jour" textFill="#2c3e50">
                                                        <font>
                                                            <Font name="System Bold" size="14.0" />
                                                        </font>
                                                    </Label>
                                                    <BarChart fx:id="occupationChart" prefHeight="300.0">
                                                        <xAxis>
                                                            <CategoryAxis fx:id="occupationXAxis" side="BOTTOM" />
                                                        </xAxis>
                                                        <yAxis>
                                                            <NumberAxis fx:id="occupationYAxis" side="LEFT" />
                                                        </yAxis>
                                                    </BarChart>
                                                </children>
                                            </VBox>
                                        </GridPane>
                                    </children>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>

                <Tab text="Répartition des salles">
                    <content>
                        <HBox spacing="20.0" style="-fx-padding: 20;">
                            <children>
                                <VBox spacing="20.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Types de salles" textFill="#2c3e50">
                                            <font>
                                                <Font name="System Bold" size="14.0" />
                                            </font>
                                        </Label>
                                        <PieChart fx:id="typeSallesChart" prefHeight="400.0" />
                                    </children>
                                </VBox>
                                <VBox spacing="20.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Équipements" textFill="#2c3e50">
                                            <font>
                                                <Font name="System Bold" size="14.0" />
                                            </font>
                                        </Label>
                                        <PieChart fx:id="equipementsChart" prefHeight="400.0" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </content>
                </Tab>

                <Tab text="Tendances">
                    <content>
                        <VBox spacing="20.0" style="-fx-padding: 20;">
                            <children>
                                <Label text="Évolution du taux d'occupation" textFill="#2c3e50">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                                <LineChart fx:id="tendanceChart" prefHeight="400.0">
                                    <xAxis>
                                        <CategoryAxis fx:id="tendanceXAxis" side="BOTTOM" />
                                    </xAxis>
                                    <yAxis>
                                        <NumberAxis fx:id="tendanceYAxis" side="LEFT" />
                                    </yAxis>
                                </LineChart>
                            </children>
                        </VBox>
                    </content>
                </Tab>

                <Tab text="Heat map">
                    <content>
                        <ScrollPane fitToWidth="true">
                            <content>
                                <VBox spacing="20.0" style="-fx-padding: 20;">
                                    <children>
                                        <Label text="Carte de chaleur d'occupation" textFill="#2c3e50">
                                            <font>
                                                <Font name="System Bold" size="14.0" />
                                            </font>
                                        </Label>
                                        <GridPane fx:id="heatMapGrid" gridLinesVisible="true" style="-fx-background-color: white;" />
                                    </children>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </center>
</BorderPane>
