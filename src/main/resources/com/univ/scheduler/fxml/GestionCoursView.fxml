<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.univ.scheduler.controller.GestionCoursController">

    <top>
        <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 2);" BorderPane.alignment="CENTER">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Label text="Gestion des cours" textFill="#2c3e50">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>
                        <Region HBox.hgrow="ALWAYS" />
                        <TextField fx:id="searchField" promptText="Rechercher un cours..." style="-fx-background-radius: 15;">
                            <HBox.margin>
                                <Insets right="10.0" />
                            </HBox.margin>
                        </TextField>
                        <Button fx:id="btnExporter" mnemonicParsing="false" style="-fx-background-color: #27ae60;" text="📥 Exporter" textFill="WHITE" />
                    </children>
                </HBox>

                <Separator prefWidth="200.0" />

                <!-- Filtres -->
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="5.0">
                            <Label text="Classe:" />
                            <ComboBox fx:id="filtreClasse" prefWidth="100.0" />
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="5.0">
                            <Label text="Enseignant:" />
                            <ComboBox fx:id="filtreEnseignant" prefWidth="150.0" />
                        </HBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.6" orientation="VERTICAL" BorderPane.alignment="CENTER">
            <items>
                <!-- Tableau des cours -->
                <VBox spacing="5.0">
                    <children>
                        <Label text="Liste des cours" textFill="#2c3e50">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Label>
                        <TableView fx:id="tableCours" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                                <TableColumn fx:id="colMatiere" prefWidth="200.0" text="Matière" />
                                <TableColumn fx:id="colEnseignant" prefWidth="150.0" text="Enseignant" />
                                <TableColumn fx:id="colClasse" prefWidth="80.0" text="Classe" />
                                <TableColumn fx:id="colGroupe" prefWidth="80.0" text="Groupe" />
                                <TableColumn fx:id="colActions" prefWidth="150.0" text="Actions" />
                            </columns>
                        </TableView>
                    </children>
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </VBox>

                <!-- Formulaire d'ajout/modification -->
                <VBox spacing="15.0" style="-fx-background-color: #f8f9fa; -fx-padding: 20; -fx-border-color: #dee2e6; -fx-border-width: 1 0 0 0;">
                    <children>
                        <Label text="Informations du cours" textFill="#2c3e50">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>

                        <GridPane hgap="15.0" vgap="15.0">
                            <columnConstraints>
                                <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" minWidth="100.0" />
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="300.0" />
                            </columnConstraints>

                            <Label text="Matière :" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                            <TextField fx:id="txtMatiere" prefWidth="400.0" promptText="Ex: Programmation Java" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                            <Label text="Enseignant :" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                            <ComboBox fx:id="cmbEnseignant" prefWidth="400.0" promptText="Sélectionner un enseignant" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                            <Label text="Classe :" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                            <ComboBox fx:id="cmbClasse" prefWidth="150.0" promptText="Classe" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                            <Label text="Groupe :" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                            <ComboBox fx:id="cmbGroupe" prefWidth="150.0" promptText="Groupe (optionnel)" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                        </GridPane>

                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <children>
                                <Button fx:id="btnAjouter" defaultButton="true" mnemonicParsing="false" style="-fx-background-color: #3498db;" text="➕ Ajouter" textFill="WHITE" />
                                <Button fx:id="btnModifier" mnemonicParsing="false" style="-fx-background-color: #f39c12;" text="✏️ Modifier" textFill="WHITE" />
                                <Button fx:id="btnSupprimer" mnemonicParsing="false" style="-fx-background-color: #e74c3c;" text="🗑️ Supprimer" textFill="WHITE" />
                                <Button fx:id="btnAnnuler" mnemonicParsing="false" style="-fx-background-color: #95a5a6;" text="❌ Annuler" textFill="WHITE" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </items>
        </SplitPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #ecf0f1; -fx-padding: 10;" BorderPane.alignment="CENTER">
            <children>
                <Label text="Statistiques :" textFill="#2c3e50">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Label>
                <Label text="Total cours :" />
                <Label fx:id="totalCoursLabel" text="0" textFill="#3498db">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Label>
                <Label text="Enseignants :" />
                <Label fx:id="totalEnseignantsLabel" text="0" textFill="#3498db">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Label>
                <Label text="Cours par classe :" />
                <Label fx:id="coursParClasseLabel" text="0" textFill="#3498db">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Label>
            </children>
        </HBox>
    </bottom>
</BorderPane>