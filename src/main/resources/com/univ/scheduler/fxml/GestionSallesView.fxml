<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<BorderPane prefHeight="700.0" prefWidth="1200.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.univ.scheduler.controller.GestionSallesController">

    <!-- Top Bar avec profil utilisateur -->
    <top>
        <VBox spacing="0">
            <!-- Profil utilisateur -->
            <HBox styleClass="profile-section" alignment="CENTER_LEFT" spacing="15.0">
                <children>
                    <ImageView fx:id="profileImage" fitHeight="50.0" fitWidth="50.0" styleClass="profile-image">
                        <image>
                            <Image url="@../images/utilisateur.png" />
                        </image>
                    </ImageView>
                    <VBox spacing="5.0">
                        <children>
                            <Label fx:id="userNameLabel" text="Admin UIDT" styleClass="profile-name" />
                            <HBox spacing="10.0">
                                <Label fx:id="userRoleBadge" text="Administrateur" styleClass="profile-role-admin" />
                                <Label text="Dernière connexion: 08/03/2026 09:30" styleClass="profile-role" />
                            </HBox>
                        </children>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="Notifications" styleClass="button-outline" />
                    <Button text="Déconnexion" styleClass="button-danger" fx:id="logoutButton" />
                </children>
                <padding>
                    <Insets top="15.0" right="20.0" bottom="15.0" left="20.0" />
                </padding>
            </HBox>

            <!-- En-tête de la page -->
            <HBox styleClass="filter-section" alignment="CENTER_LEFT" spacing="15.0">
                <children>
                    <Label text="Gestion des salles" styleClass="card-header" />
                    <Region HBox.hgrow="ALWAYS" />

                    <!-- Barre de recherche -->
                    <HBox styleClass="search-bar" spacing="10.0">
                        <children>
                            <TextField fx:id="searchField" promptText="Rechercher une salle..." HBox.hgrow="ALWAYS" />
                            <Button text="🔍" styleClass="search-button" />
                        </children>
                    </HBox>

                    <Button fx:id="btnExporter" text="📥 Exporter" styleClass="button-success" />
                </children>
                <padding>
                    <Insets top="15.0" right="20.0" bottom="15.0" left="20.0" />
                </padding>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: transparent;">
            <content>
                <VBox spacing="20.0" style="-fx-padding: 20;">
                    <children>
                        <!-- Section Filtres -->
                        <VBox styleClass="card" spacing="15.0">
                            <children>
                                <Label text="Filtres avancés" styleClass="card-header" />

                                <HBox spacing="20.0" alignment="CENTER_LEFT" >
                                    <children>
                                        <VBox spacing="5.0">
                                            <Label text="Type" styleClass="filter-title" />
                                            <ComboBox fx:id="typeFilter" prefWidth="150.0" promptText="Tous" />
                                        </VBox>
                                        <VBox spacing="5.0">
                                            <Label text="Bâtiment" styleClass="filter-title" />
                                            <ComboBox fx:id="batimentFilter" prefWidth="200.0" promptText="Tous" />
                                        </VBox>
                                        <VBox spacing="5.0">
                                            <Label text="Capacité minimum" styleClass="filter-title" />
                                            <Spinner fx:id="capaciteMinFilter" prefWidth="120.0" />
                                        </VBox>
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <Label text="Équipements" styleClass="filter-title" />
                                            <ListView fx:id="equipementsList" prefHeight="60.0" prefWidth="250.0" />
                                        </VBox>
                                    </children>
                                </HBox>

                                <HBox spacing="10.0" alignment="CENTER_RIGHT">
                                    <children>
                                        <Button text="Réinitialiser" styleClass="button-outline" />
                                        <Button text="Appliquer les filtres" styleClass="button-primary" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <!-- Statistiques rapides -->
                        <HBox spacing="15.0" alignment="CENTER_LEFT" >
                            <children>
                                <VBox styleClass="stat-card" alignment="CENTER" spacing="5.0">
                                    <Label text="🏢" styleClass="stat-icon" />
                                    <Label fx:id="totalSallesLabel" text="24" styleClass="stat-value" />
                                    <Label text="Total salles" styleClass="stat-label" />
                                </VBox>
                                <VBox styleClass="stat-card" alignment="CENTER" spacing="5.0">
                                    <Label text="📊" styleClass="stat-icon" />
                                    <Label fx:id="capaciteMoyenneLabel" text="45" styleClass="stat-value" />
                                    <Label text="Capacité moyenne" styleClass="stat-label" />
                                </VBox>
                                <VBox styleClass="stat-card" alignment="CENTER" spacing="5.0">
                                    <Label text="📈" styleClass="stat-icon" />
                                    <Label fx:id="tauxOccupationLabel" text="65%" styleClass="stat-value" />
                                    <Label text="Taux d'occupation" styleClass="stat-label" />
                                </VBox>
                                <ProgressBar fx:id="occupationBar" prefWidth="150.0" progress="0.65" />
                            </children>
                        </HBox>

                        <!-- Tableau des salles -->
                        <VBox styleClass="card" spacing="15.0">
                            <children>
                                <Label text="Liste des salles" styleClass="card-header" />
                                <TableView fx:id="tableSalles" VBox.vgrow="ALWAYS" prefHeight="300.0">
                                    <columns>
                                        <TableColumn fx:id="colNumero" prefWidth="120.0" text="Numéro" />
                                        <TableColumn fx:id="colCapacite" prefWidth="100.0" text="Capacité" />
                                        <TableColumn fx:id="colType" prefWidth="100.0" text="Type" />
                                        <TableColumn fx:id="colBatiment" prefWidth="150.0" text="Bâtiment" />
                                        <TableColumn fx:id="colEquipements" prefWidth="300.0" text="Équipements" />
                                        <TableColumn fx:id="colActions" prefWidth="150.0" text="Actions" />
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>

                        <!-- Formulaire d'ajout/modification -->
                        <VBox styleClass="card" spacing="15.0">
                            <children>
                                <Label fx:id="formTitle" text="Ajouter une salle" styleClass="card-header" />

                                <GridPane hgap="20.0" vgap="15.0">
                                    <columnConstraints>
                                        <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" minWidth="100.0" />
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="200.0" prefWidth="200.0" />
                                        <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" minWidth="100.0" />
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="200.0" prefWidth="200.0" />
                                    </columnConstraints>

                                    <Label text="Numéro :" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                    <TextField fx:id="txtNumero" promptText="Ex: TD101" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                    <Label text="Capacité :" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                                    <Spinner fx:id="txtCapacite" prefWidth="150.0" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                                    <Label text="Type :" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                    <ComboBox fx:id="cmbType" prefWidth="150.0" promptText="Sélectionner" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                    <Label text="Bâtiment :" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                                    <ComboBox fx:id="cmbBatiment" prefWidth="200.0" promptText="Sélectionner" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                                </GridPane>

                                <Label text="Équipements disponibles :" styleClass="filter-title" />
                                <ListView fx:id="equipementsSelection" prefHeight="100.0" />

                                <HBox alignment="CENTER_RIGHT" spacing="10.0" >
                                    <children>
                                        <Button fx:id="btnAnnuler" text="❌ Annuler" styleClass="button-outline" />
                                        <Button fx:id="btnSupprimer" text="🗑️ Supprimer" styleClass="button-danger" />
                                        <Button fx:id="btnModifier" text="✏️ Modifier" styleClass="button-warning" />
                                        <Button fx:id="btnAjouter" text="➕ Ajouter" styleClass="button-success" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>